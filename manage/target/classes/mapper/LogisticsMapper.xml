<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mall.mapper.LogisticsMapper">
    <resultMap id="LogisticsResultMap" type="com.mall.entity.Logistics">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="order_no" property="orderNo"/>
        <result column="shipping_company" property="shippingCompany"/>
        <result column="shipping_no" property="shippingNo"/>
        <result column="shipping_status" property="shippingStatus"/>
        <result column="tracking_info" property="trackingInfo"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="LogisticsResultMap">
        SELECT * FROM logistics WHERE id = #{id}
    </select>

    <select id="selectByOrderId" resultMap="LogisticsResultMap">
        SELECT * FROM logistics WHERE order_id = #{orderId}
    </select>

    <select id="selectList" resultMap="LogisticsResultMap">
        SELECT * FROM logistics
        <where>
            <if test="orderNo != null and orderNo != ''">
                AND order_no LIKE CONCAT('%', #{orderNo}, '%')
            </if>
            <if test="shippingStatus != null">
                AND shipping_status = #{shippingStatus}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO logistics (order_id, order_no, shipping_company, shipping_no, shipping_status, tracking_info)
        VALUES (#{orderId}, #{orderNo}, #{shippingCompany}, #{shippingNo}, #{shippingStatus}, #{trackingInfo})
    </insert>

    <update id="update">
        UPDATE logistics
        <set>
            <if test="shippingCompany != null">shipping_company = #{shippingCompany},</if>
            <if test="shippingNo != null">shipping_no = #{shippingNo},</if>
            <if test="shippingStatus != null">shipping_status = #{shippingStatus},</if>
            <if test="trackingInfo != null">tracking_info = #{trackingInfo},</if>
            update_time = CURRENT_TIMESTAMP
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM logistics WHERE id = #{id}
    </delete>
</mapper>